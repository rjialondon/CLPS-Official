# 三才并行计算报告
# 天地人三路并发，各算一道数学命题，合师后汇总验证

师 "天" "天任务.dao"
师 "地" "地任务.dao"
师 "人" "人任务.dao"

合

# 离·跨界取六个结果
离 "天和"   天 "和"
离 "天N"    天 "N"
离 "地奇"   地 "奇和"
离 "地N"    地 "N"
离 "人卦"   人 "卦序和"
离 "人卦数" 人 "卦数"

# 兑·报告
兑 "天N"
兑 "天和"
兑 "地N"
兑 "地奇"
兑 "人卦数"
兑 "人卦"

# 讼·总验（三命题同时成立）
