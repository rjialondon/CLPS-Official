# 震(51)·震为雷卦测试 — 定时器/心跳

# 歇：睡眠（毫秒）
震 "slept" 【震为雷卦】 歇 50
兑 "slept"
讼 "slept" == 50

# 起：创建单次定时器（100ms到期）
震 "r1" 【震为雷卦】 起 "t1" 100
讼 "r1" == 1

# 距：已过时间应接近0
震 "el0" 【震为雷卦】 距 "t1"
兑 "el0"
讼 "el0" >= 0

# 到：未到期 → 0
震 "fired0" 【震为雷卦】 到 "t1" 100
兑 "fired0"

# 歇 120ms 等超过100ms
震 "r2" 【震为雷卦】 歇 120

# 到：已到期 → 1
震 "fired1" 【震为雷卦】 到 "t1" 100
兑 "fired1"
讼 "fired1" == 1

# 距：应 >= 120ms
震 "el1" 【震为雷卦】 距 "t1"
兑 "el1"
讼 "el1" >= 100

# 撤：删除定时器 → 1
震 "del1" 【震为雷卦】 撤 "t1"
兑 "del1"
讼 "del1" == 1

# 撤不存在的定时器 → 0
震 "del2" 【震为雷卦】 撤 "nonexist"
兑 "del2"
讼 "del2" == 0

# 周期定时器：每 50ms 一次
震 "rp" 【震为雷卦】 周 "beat" 50
讼 "rp" == 1

# 歇 0ms：未到期，滴 → 0
震 "tick0" 【震为雷卦】 滴 "beat"
兑 "tick0"
讼 "tick0" == 0

# 歇 60ms → 第一次触发
震 "r3" 【震为雷卦】 歇 60
震 "tick1" 【震为雷卦】 滴 "beat"
兑 "tick1"
讼 "tick1" == 1

# 次：已触发 1 次
震 "cnt" 【震为雷卦】 次 "beat"
兑 "cnt"
讼 "cnt" == 1

# 再歇 60ms → 第二次触发
震 "r4" 【震为雷卦】 歇 60
震 "tick2" 【震为雷卦】 滴 "beat"
兑 "tick2"
讼 "tick2" == 1

震 "cnt2" 【震为雷卦】 次 "beat"
兑 "cnt2"
讼 "cnt2" == 2

兑 "震卦测试通过"
