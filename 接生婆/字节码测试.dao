# 字节码编译器补全测试 — 恒/蹇/小畜三卦
# 既济(63)·水在火上，已成之象，三卦入字节码方为圆满

# ── 恒(32)·只读常量 ──
恒 "圆周率" 3.14159
兑 "圆周率"
讼 "圆周率" == 3.14159

恒 "道名" "道可道" 火
兑 "道名"
讼 "道名" == "道可道"

# ── 小畜(9)·列表积累 ──
小畜 "六爻"
小畜 "六爻" 1
小畜 "六爻" 2
小畜 "六爻" 3
兑 "六爻"

# ── 蹇(39)·错误恢复 ──
乾 "正常" 0
蹇 {
    乾 "x" 100
    讼 "x" == 100
    震 "正常" + 1
}
兑 "正常"
讼 "正常" == 1

# 蹇捕获错误
乾 "捕获到" 0
蹇 {
    讼 "不存在的key" == 1
} 化 "错误信息" {
    兑 "错误信息"
    震 "捕获到" + 1
}
兑 "捕获到"
讼 "捕获到" == 1

兑 "字节码三卦测试通过"
