# 万物库批量测试 — 颐(27)/晋(35)/离(30)/丰(55)/噬嗑(21)/贲(22)

# ── 颐(27) 山雷颐卦·数学 ──────────────────────────────────────────
震 "sin90" 【山雷颐卦】 正弦 1.5707963
兑 "sin90"
# sin(π/2) ≈ 1.0，取整应为1
震 "sin_int" 【山雷颐卦】 四舍五入 1.0
讼 "sin_int" == 1

震 "sqrt4" 【山雷颐卦】 开方 4.0
震 "sqrt4_int" 【山雷颐卦】 四舍五入 2.0
讼 "sqrt4_int" == 2

震 "pow" 【山雷颐卦】 幂次 2.0 10.0
震 "pow_int" 【山雷颐卦】 四舍五入 1024.0
讼 "pow_int" == 1024

震 "abs" 【山雷颐卦】 绝对值 -42.0
震 "abs_int" 【山雷颐卦】 四舍五入 42.0
讼 "abs_int" == 42

震 "floor" 【山雷颐卦】 下取整 3.7
讼 "floor" == 3

震 "ceil" 【山雷颐卦】 上取整 3.1
讼 "ceil" == 4

# ── 晋(35) 火地晋卦·文件系统 ──────────────────────────────────────
震 "exists" 【火地晋卦】 存在 "../易经.md"
讼 "exists" == 1
兑 "exists"

震 "no_exists" 【火地晋卦】 存在 "不存在的文件.xyz"
讼 "no_exists" == 0

震 "fsize" 【火地晋卦】 大小 "../易经.md"
兑 "fsize"
讼 "fsize" > 0

# 建目录测试
震 "mkdir_ok" 【火地晋卦】 建目录 "_test_dir_临时"
讼 "mkdir_ok" == 1
震 "dir_exists" 【火地晋卦】 存在 "_test_dir_临时"
讼 "dir_exists" == 1
# 清理
震 【火地晋卦】 删除 "_test_dir_临时"
震 "dir_gone" 【火地晋卦】 存在 "_test_dir_临时"
讼 "dir_gone" == 0

# ── 离(30) 离为火卦·字符串 ──────────────────────────────────────────
震 "upper" 【离为火卦】 大写 "hello"
讼 "upper" == "HELLO"
兑 "upper"

震 "lower" 【离为火卦】 小写 "WORLD"
讼 "lower" == "world"

震 "trim" 【离为火卦】 去空 "  道·码  "
讼 "trim" == "道·码"
兑 "trim"

震 "sub" 【离为火卦】 子串 "abcdef" 1 3
讼 "sub" == "bcd"

震 "idx" 【离为火卦】 查找 "hello world" "world"
讼 "idx" == 6

震 "len" 【离为火卦】 长度 "道·码"
兑 "len"
讼 "len" > 0

震 "rep" 【离为火卦】 替换 "hello world" "world" "道"
讼 "rep" == "hello 道"
兑 "rep"

# ── 丰(55) 雷火丰卦·格式化 ─────────────────────────────────────────
震 "fmt1" 【雷火丰卦】 格式化 "第%d卦" 64
讼 "fmt1" == "第64卦"
兑 "fmt1"

震 "fmt2" 【雷火丰卦】 格式化 "%s=%g" "PI" 3.14
讼 "fmt2" == "PI=3.14"
兑 "fmt2"

# ── 噬嗑(21) 火雷噬嗑卦·正则 ──────────────────────────────────────
震 "m1" 【火雷噬嗑卦】 匹配 "[0-9]+" "abc123"
讼 "m1" == 1
兑 "m1"

震 "m2" 【火雷噬嗑卦】 匹配 "[0-9]+" "abcdef"
讼 "m2" == 0

震 "found" 【火雷噬嗑卦】 搜寻 "[0-9]+" "abc 456 def"
讼 "found" == "456"
兑 "found"

震 "repl" 【火雷噬嗑卦】 替换 "[aeiou]" "hello world" "X"
讼 "repl" == "hXllX wXrld"
兑 "repl"

# ── 贲(22) 山火贲卦·JSON ────────────────────────────────────────────
震 "json1" 【山火贲卦】 序列化 42
讼 "json1" == "42"
兑 "json1"

震 "json2" 【山火贲卦】 序列化 "道·码"
讼 "json2" == "\"道·码\""
兑 "json2"

震 "back" 【山火贲卦】 反序列化 "99"
讼 "back" == 99
兑 "back"

震 "back2" 【山火贲卦】 反序列化 "\"易\""
讼 "back2" == "易"
兑 "back2"

兑 "全部测试通过"
