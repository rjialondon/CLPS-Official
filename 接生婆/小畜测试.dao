# 小畜卦测试 — 密云不雨，积而未施

# 辟出空列表
小畜 "卦名集"

# 向列表追加值
小畜 "卦名集" "乾"
小畜 "卦名集" "坤"
小畜 "卦名集" "屯"
小畜 "卦名集" "蒙"
小畜 "卦名集" "需"
小畜 "卦名集" "讼"
小畜 "卦名集" "师"
小畜 "卦名集" "比"
小畜 "卦名集" "小畜"

# 兑·显像（整个列表）
兑 "卦名集"

# 混合类型列表
小畜 "混合"
小畜 "混合" 1
小畜 "混合" 3.14
小畜 "混合" "文字"
小畜 "混合" 42

兑 "混合"

# 复·循环积累
小畜 "平方集"
复 5 {
    小畜 "平方集" $i
}
兑 "平方集"

# 巽·列表遍历
# 元变量名不带引号 → IDENT 查词典，取当前迭代元素的实际值
乾 "总和" 0
巽 "平方集" "元" {
    震 "总和" + 元
}
# 0+1+2+3+4 = 10
兑 "总和"
讼 "总和" == 10
