# 地：奇数求和
# 1+3+5+...+(2N-1) = N²，取 N=100，结果=10000
#
# 证明：∑(2i+1) for i=0..N-1 = 2×∑i + N = N(N-1) + N = N²
# 实现：每次循环将 $i 加两次（= 2i），循环后再加 N
#   复 100 中 $i=0..99
#   2×(0+1+...+99) = 2×4950 = 9900
#   震 "奇和" + 100  → 9900+100 = 10000 = 100²

乾 "N"    100
乾 "奇和" 0

复 100 {
    震 "奇和" + $i
    震 "奇和" + $i
}
震 "奇和" + 100

讼 "奇和" == 10000
兑 "奇和"
兑 "N"
