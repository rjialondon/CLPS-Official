# 集成演示服务端
# 甲卦·节(60)令牌桶限流 + 乙卦·习坎(29)签名验证 + 涣(59)广播 + 观(20)日志

# ── 初始化 ───────────────────────────────────────────
震 【地风观卦】 清观
震 【地风观卦】 立标 "服务端启动"

# 令牌桶：容量5，每秒补充10个
震 【水泽节卦】 制桶 "API桶" 5 10
震 【地风观卦】 观察 "信" "令牌桶已建立（容量5，10令/秒）"

# 数据库初始化
震 【地泽临卦】 开库 ":memory:"
震 【地泽临卦】 执行 "CREATE TABLE 道言 (id INTEGER PRIMARY KEY, 言 TEXT)"
震 【地泽临卦】 事务
震 【地泽临卦】 执行 "INSERT INTO 道言 (言) VALUES ('道可道，非常道')"
震 【地泽临卦】 执行 "INSERT INTO 道言 (言) VALUES ('天下皆知美之为美，斯恶已')"
震 【地泽临卦】 执行 "INSERT INTO 道言 (言) VALUES ('上善若水')"
震 【地泽临卦】 提交

# HTTP服务器
震 【火水未济卦】 启服 "集成服" 17067
震 【地风观卦】 观察 "信" "HTTP服务器已启动，端口 17067"

# 广播就绪信号
震 【风水涣卦】 广发 "集成总线" "控制" "服务端就绪"
震 【泽雷随卦】 发 "集成队列" "就绪" "集成服务端启动"

# ── 请求1：道德经第1章 ─────────────────────────────
震 "req1" 【火水未济卦】 待请 "集成服"

# 取令（限流）
震 "令1" 【水泽节卦】 取令 "API桶"
震 【地风观卦】 观察 "信" "请求1 处理，剩余令牌"

# 查询数据
震 "行1" 【地泽临卦】 查询 "SELECT 言 FROM 道言 WHERE id=1"

# 计算HMAC签名（服务端签名响应，可供客户端验证）
震 "签1" 【习坎卦】 签名 "服务器密钥" "道可道，非常道"
兑 "签1"

# 广播处理事件
震 【风水涣卦】 广发 "集成总线" "请求" "已处理请求1：道德经第1章"

震 【火水未济卦】 回应 "集成服" 200 "道可道，非常道\n"

# ── 请求2：道德经第2章 ─────────────────────────────
震 "req2" 【火水未济卦】 待请 "集成服"
震 "令2" 【水泽节卦】 取令 "API桶"
震 【地风观卦】 观察 "信" "请求2 处理，剩余令牌"
震 "行2" 【地泽临卦】 查询 "SELECT 言 FROM 道言 WHERE id=2"
震 【风水涣卦】 广发 "集成总线" "请求" "已处理请求2：道德经第2章"
震 【火水未济卦】 回应 "集成服" 200 "天下皆知美之为美，斯恶已\n"

# ── 请求3：道德经第8章 ─────────────────────────────
震 "req3" 【火水未济卦】 待请 "集成服"
震 "令3" 【水泽节卦】 取令 "API桶"
震 【地风观卦】 观察 "信" "请求3 处理，剩余令牌"
震 "行3" 【地泽临卦】 查询 "SELECT 言 FROM 道言 WHERE id=3"
震 "签3" 【习坎卦】 签名 "服务器密钥" "上善若水"
震 【风水涣卦】 广发 "集成总线" "请求" "已处理请求3：道德经第8章"
震 【火水未济卦】 回应 "集成服" 200 "上善若水\n"

# ── 关闭 ─────────────────────────────────────────────
震 【火水未济卦】 停服 "集成服"

# 广播完成
震 【风水涣卦】 广发 "集成总线" "控制" "服务端完成"
震 【泽雷随卦】 发 "集成队列" "完成" "集成服务端退出"

# 统计
震 "统计" 【地风观卦】 统计
兑 "统计"
