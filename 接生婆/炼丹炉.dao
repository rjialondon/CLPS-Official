# 炼丹炉 — 万物库四卦联合演示
# 对照 PDF16 的原始程序，用新语法重写

结界 "炼丹" {
    乾 "计数"  0  金

    复 3 {
        # 大衍之数：推演随机原石
        震 "原石"  【大衍之数】  推演变数  9999

        # 大衍之数：掩藏天机（哈希炼化）
        震 "密符"  【大衍之数】  掩藏天机  原石

        # 厚土艮卦：刻石记录到文件
        震  【厚土艮卦】  刻石记录  密符

        # 四时革卦：问天时（时间戳）
        震 "时刻"  【四时革卦】  问天时

        # 兑出结果
        兑 "原石"
        兑 "密符"
        兑 "时刻"

        震 "计数"  +  1
    }

    兑 "计数"
    坤
}
