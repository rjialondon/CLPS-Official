# 履卦测试 — 履虎尾，不咥人
# 甲方声明意图，OS 乙方决定放行与否

# 进程号
震 "pid" 【天泽履卦】 进程号
兑 "pid"
讼 "pid" > 0

# 环境变量
震 "shell" 【天泽履卦】 环境 "SHELL"
兑 "shell"
讼 "shell" != ""

# 执令：问天时（date）
震 "日期" 【天泽履卦】 执令 "date '+%Y-%m-%d'"
兑 "日期"
讼 "日期" != ""

# 执令：列出当前目录 .dao 文件数
震 "数量" 【天泽履卦】 执令 "ls *.dao | wc -l | tr -d ' '"
兑 "数量"
讼 "数量" != ""

# 执令结果存入列表
小畜 "系统信息"
小畜 "系统信息" "pid已取"
小畜 "系统信息" "shell已读"
小畜 "系统信息" "日期已问"
兑 "系统信息"
