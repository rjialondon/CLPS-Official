# 恒(32) 测试 — 雷风恒卦·常道不变
# 测试1：恒 声明只读常量，兑 可以读取
恒 "PI" 31415 金
兑 "PI"
讼 "PI" == 31415

# 测试2：恒 + 五行自动推断（字符串→火）
恒 "名称" "道·码"
兑 "名称"
讼 "名称" == "道·码"

# 测试3：乾 可以存相同 key 的可变量
乾 "可变" 100 金
震 "可变" + 1
讼 "可变" == 101

# 测试4：蹇 捕获尝试修改恒量的错误
蹇 {
    震 "PI" + 1
} 化 "错误" {
    兑 "错误"
    讼 "错误" != ""
}

# 测试5：恒 + 蹇 组合 — PI 仍然保持原值
讼 "PI" == 31415

# 测试6：蹇 无错误时不执行化块
乾 "计" 0 金
蹇 {
    震 "计" + 10
} 化 "e" {
    震 "计" + 999
}
讼 "计" == 10
兑 "计"
