# 道·码 (CLPS) 第一个 .dao 程序
# 测试：结界 乾 震 坎 兑 变 复 巽

结界 "货币系统" {
    乾 "余额"  1000  金
    乾 "利率"  0.05  水
    震 "余额"  +  200
    兑 "余额"
    坎 "余额"  +  500
    兑 "余额"
    变 "余额"  木
    坤
}

# 复卦：循环三次，每次加 $i
结界 "计数演示" {
    乾 "总计"  0  金
    复 3 {
        震 "总计"  +  $i
    }
    兑 "总计"
}

# 巽卦：遍历全部资源
结界 "仓库" {
    乾 "金库"  9999  金
    乾 "水库"  500   水
    乾 "木库"  200   木
    巽
}
