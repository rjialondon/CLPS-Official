# 谦卦测试 — 地中有山，谦，君子有终
# 裒多益寡，称物平施 — 配额限制，公平分配

# ── 建立配额池（容量 10）──────────────────────────────
震 "建" 【地山谦卦】 限额 "资源池" 10
兑 "建"
讼 "建" == 10

# ── 申请资源 ─────────────────────────────────────────
震 "批甲" 【地山谦卦】 申请 "资源池" 3
兑 "批甲"
讼 "批甲" == 1

震 "批乙" 【地山谦卦】 申请 "资源池" 5
兑 "批乙"
讼 "批乙" == 1

# 余量2，申请4 → 不足，拒绝
震 "批丙" 【地山谦卦】 申请 "资源池" 4
兑 "批丙"
讼 "批丙" == 0

# ── 余量查询 ─────────────────────────────────────────
震 "余" 【地山谦卦】 余量 "资源池"
兑 "余"
讼 "余" == 2

# ── 归还 → 再申请 ────────────────────────────────────
震 "还甲" 【地山谦卦】 归还 "资源池" 3
兑 "还甲"
讼 "还甲" == 5

震 "批丁" 【地山谦卦】 申请 "资源池" 4
兑 "批丁"
讼 "批丁" == 1

震 "余终" 【地山谦卦】 余量 "资源池"
兑 "余终"
讼 "余终" == 1

# ── 归还不超容量（溢出保护）─────────────────────────
震 "还乙" 【地山谦卦】 归还 "资源池" 100
兑 "还乙"
讼 "还乙" == 10

# ── 师·联动：三任务争配额，量力而行，不足则自谦退让 ─
# 配额池容量5，三任务各申请3，最多一个完整批准，余者降级
震 "建二" 【地山谦卦】 限额 "小池" 5

师 "竞甲" "谦卦竞甲.dao"
师 "竞乙" "谦卦竞乙.dao"
师 "竞丙" "谦卦竞丙.dao"
合

# 三任务各投回申请结果（1=批准 0=拒绝）到同人渠道
# 汇总：批准数 <= 1（5容量，每个申请3，最多一个能满足）
小畜 "结果集"
复 3 {
    震 "r" 【天火同人卦】 取 "谦渠"
    小畜 "结果集" r
}
兑 "结果集"

震 "批准数" 【火天大有卦】 总 结果集
兑 "批准数"
讼 "批准数" <= 1
