# 书签 REST API 服务端
# 泰卦(11)·地天泰：天地交通，万物通泰
# 五卦协作：未济(64)服务器 + 临(19)数据库 + 观(20)日志 + 贲(22)JSON + 丰(55)格式化

# ── 初始化 ──────────────────────────────────────────
# 开启内存数据库
震 【地泽临卦】 开库 ":memory:"
震 【地泽临卦】 执行 "CREATE TABLE 书签 (id INTEGER PRIMARY KEY AUTOINCREMENT, 标题 TEXT, 网址 TEXT)"

# 插入示例数据
震 【地泽临卦】 事务
震 【地泽临卦】 执行 "INSERT INTO 书签 (标题, 网址) VALUES ('道德经', 'https://example.com/daodejing')"
震 【地泽临卦】 执行 "INSERT INTO 书签 (标题, 网址) VALUES ('易经', 'https://example.com/yijing')"
震 【地泽临卦】 提交

震 【地风观卦】 观察 "信" "书签数据库已就绪"

# ── 启动 HTTP 服务器 ────────────────────────────────
震 【火水未济卦】 启服 "书签服" 17065
震 【地风观卦】 观察 "信" "HTTP服务端就绪，端口 17065"

# 通知主线服务端已就绪
震 【泽雷随卦】 发 "书签总线" "就绪" "服务端已启动"

# ── 请求1：GET /bookmarks ──────────────────────────
震 "请求1" 【火水未济卦】 待请 "书签服"
震 【地风观卦】 观察 "信" "收到请求1"

震 "行列" 【地泽临卦】 查询 "SELECT id, 标题, 网址 FROM 书签"
震 "json1" 【山火贲卦】 序列化 "[书签列表]"
震 【火水未济卦】 回应 "书签服" 200 "书签：道德经|易经\n"

# ── 请求2：POST /bookmark（查询特定书签）──────────
震 "请求2" 【火水未济卦】 待请 "书签服"
震 【地风观卦】 观察 "信" "收到请求2"

震 "道行" 【地泽临卦】 查询 "SELECT 标题, 网址 FROM 书签 WHERE 标题='道德经'"
震 【火水未济卦】 回应 "书签服" 200 "道德经找到\n"

# ── 关闭服务端 ──────────────────────────────────────
震 【火水未济卦】 停服 "书签服"
震 【地风观卦】 观察 "信" "服务端已关闭"

# 统计
震 "统计" 【地风观卦】 统计
兑 "统计"

# 通知主线结束
震 【泽雷随卦】 发 "书签总线" "完成" "服务端退出"
