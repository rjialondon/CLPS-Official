# 随(17) 泽雷随卦·事件总线测试
# 不需要网络，纯进程内 pub/sub

# 测试1：建总线，返回名称
震 "bus" 【泽雷随卦】 建总线 "消息总线"
讼 "bus" == "消息总线"
兑 "bus"

# 测试2：发射事件
震 "n1" 【泽雷随卦】 发 "消息总线" "点击" 42
讼 "n1" == 1

震 "n2" 【泽雷随卦】 发 "消息总线" "点击" 99
讼 "n2" == 2

震 "n3" 【泽雷随卦】 发 "消息总线" "键入" "hello"
讼 "n3" == 1

# 测试3：积压数量
震 "click_q" 【泽雷随卦】 积压 "消息总线" "点击"
讼 "click_q" == 2
兑 "click_q"

震 "key_q" 【泽雷随卦】 积压 "消息总线" "键入"
讼 "key_q" == 1

# 测试4：试收（非阻塞，FIFO顺序）
震 "ev1" 【泽雷随卦】 试收 "消息总线" "点击"
讼 "ev1" == 42
兑 "ev1"

震 "ev2" 【泽雷随卦】 试收 "消息总线" "点击"
讼 "ev2" == 99

# 测试5：试收空队列 → None
震 "ev3" 【泽雷随卦】 试收 "消息总线" "点击"
兑 "ev3"

# 测试6：键入事件
震 "kev" 【泽雷随卦】 试收 "消息总线" "键入"
讼 "kev" == "hello"

# 测试7：师+随 — 子任务发事件，主线收事件
师 "发令者" "随卦发令.dao"
合
震 "结果" 【泽雷随卦】 收 "总线" "完成"
兑 "结果"
讼 "结果" == "任务完成"
