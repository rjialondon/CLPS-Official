# 同人测试 — 天与火，志同道合，消息传递
# 同人于野，亨。利涉大川，利君子贞

# ── 单线程：投三取三（先进先出）─────────────────────────
震 "投甲" 【天火同人卦】 投 "渠道" "天"
震 "投乙" 【天火同人卦】 投 "渠道" "地"
震 "投丙" 【天火同人卦】 投 "渠道" "人"
兑 "投丙"

震 "取甲" 【天火同人卦】 取 "渠道"
兑 "取甲"
讼 "取甲" == "天"

震 "取乙" 【天火同人卦】 取 "渠道"
讼 "取乙" == "地"

震 "取丙" 【天火同人卦】 取 "渠道"
讼 "取丙" == "人"

# ── 试取：空队列超时，返回空串 ──────────────────────────
震 "试甲" 【天火同人卦】 试 "渠道" 50
兑 "试甲"
讼 "试甲" == ""

# ── 师·联动：发令者投三则，主线阻塞取之 ─────────────────
# 取（阻塞）自然处理竞态：无消息时挂起，消息到则醒起
师 "发令者" "同人发令.dao"

震 "讯甲" 【天火同人卦】 取 "天路"
兑 "讯甲"
讼 "讯甲" == "卯"

震 "讯乙" 【天火同人卦】 取 "天路"
兑 "讯乙"
讼 "讯乙" == "午"

震 "讯丙" 【天火同人卦】 取 "天路"
兑 "讯丙"
讼 "讯丙" == "酉"

合
