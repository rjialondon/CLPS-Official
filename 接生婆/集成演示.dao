# 三集群联动集成演示
# 节(60)限流 + 习坎(29)安全 + 涣(59)广播 + 解(40)解析 + 观(20)监控
# 泰卦(11)：天地交通，万物通泰

震 【地风观卦】 清观
震 【地风观卦】 立标 "全程"
震 【地风观卦】 观察 "信" "三集群联动集成演示启动"

# ── 集群乙：客户端HMAC预签名 ─────────────────────────
# 客户端对每个请求URL进行HMAC签名（保证请求合法性）
震 "sig1" 【习坎卦】 签名 "客户端密钥" "http://127.0.0.1:17067/dao1"
震 "sig2" 【习坎卦】 签名 "客户端密钥" "http://127.0.0.1:17067/dao2"
震 "sig3" 【习坎卦】 签名 "客户端密钥" "http://127.0.0.1:17067/dao3"
震 【地风观卦】 观察 "信" "HMAC签名已生成"

# 验证签名为64字符十六进制
讼 "sig1" != ""
讼 "sig2" != ""
讼 "sig3" != ""

# ── 集群甲：订阅涣卦广播频道 ─────────────────────────
震 【风水涣卦】 订阅 "集成总线" "控制" "控制观察员"
震 【风水涣卦】 订阅 "集成总线" "请求" "请求观察员"
震 【地风观卦】 观察 "信" "已订阅广播频道"

# ── 启动服务端子任务 ──────────────────────────────────
师 "集成服务端" "集成服务端.dao"

# 等待服务端就绪（随卦工作队列）
震 "就绪" 【泽雷随卦】 收 "集成队列" "就绪"
兑 "就绪"
讼 "就绪" == "集成服务端启动"

# 等待涣卦广播就绪信号
震 "广就绪" 【风水涣卦】 候播 "集成总线" "控制" "控制观察员" 3000
兑 "广就绪"
讼 "广就绪" == "服务端就绪"
震 【地风观卦】 观察 "信" "服务端就绪，开始发送请求"

# ── 集群丙：客户端构造并发送请求 ─────────────────────
# 请求1：解析URL路径 + 发送请求
震 "url1" 【雷水解卦】 解路 "http://127.0.0.1:17067/dao1?sig=abc123"
兑 "url1"
讼 "url1" == "/dao1"

震 "r1" 【火山旅卦】 访 "http://127.0.0.1:17067/dao1"
兑 "r1"
讼 "r1" != ""

# 接收涣卦广播事件1
震 "ev1" 【风水涣卦】 候播 "集成总线" "请求" "请求观察员" 3000
兑 "ev1"
讼 "ev1" != ""

# 请求2
震 "r2" 【火山旅卦】 访 "http://127.0.0.1:17067/dao2"
兑 "r2"
讼 "r2" != ""

震 "ev2" 【风水涣卦】 候播 "集成总线" "请求" "请求观察员" 3000
兑 "ev2"
讼 "ev2" != ""

# 请求3
震 "r3" 【火山旅卦】 访 "http://127.0.0.1:17067/dao3"
兑 "r3"
讼 "r3" != ""

震 "ev3" 【风水涣卦】 候播 "集成总线" "请求" "请求观察员" 3000
兑 "ev3"
讼 "ev3" != ""

# ── 响应内容解析 ─────────────────────────────────────
# 用 Base64 编解码验证响应数据完整性
震 "r1_b64" 【习坎卦】 编码 "r1"
讼 "r1_b64" != ""

# URL编码响应（模拟传输）
震 "r1_enc" 【习坎卦】 网址编 "r1"
讼 "r1_enc" != ""

# 解分响应中的换行
震 "r1_lines" 【雷水解卦】 解分 "r1" "\n"
兑 "r1_lines"

# ── 等待服务端广播完成 ───────────────────────────────
震 "完成广播" 【风水涣卦】 候播 "集成总线" "控制" "控制观察员" 5000
兑 "完成广播"
讼 "完成广播" == "服务端完成"

# 合并子任务
合
震 【泽雷随卦】 试收 "集成队列" "完成"

# ── 量时统计 ─────────────────────────────────────────
震 "总耗时" 【地风观卦】 量时 "全程"
兑 "总耗时"

震 "统计" 【地风观卦】 统计
兑 "统计"

震 "日志" 【地风观卦】 回看 8
兑 "日志"

兑 "三集群联动集成演示通过"
