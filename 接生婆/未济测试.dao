# 未济(64) + 旅(56) 集成测试 — HTTP 服务端+客户端
# 师 启动 HTTP 服务端；主线用旅卦访问；验证响应

# 启动服务端子任务
师 "服务端" "未济服务端.dao"

# 等待服务端就绪（让服务端有时间绑定端口）
震 【四时革卦】 斗转星移 200

# 第一次 GET 请求
蹇 {
    震 "r1" 【火山旅卦】 访 "http://127.0.0.1:17064/"
    兑 "r1"
    讼 "r1" == "道可道，非常道\n"
} 化 "e1" {
    兑 "e1"
}

# 第二次 GET 请求
蹇 {
    震 "r2" 【火山旅卦】 访 "http://127.0.0.1:17064/名"
    兑 "r2"
    讼 "r2" == "名可名，非常名\n"
} 化 "e2" {
    兑 "e2"
}

# 等待服务端任务结束
合

# 确认服务端已通知
震 "srv_end" 【泽雷随卦】 试收 "未济总线" "完成"
兑 "srv_end"
讼 "srv_end" == "服务端结束"

兑 "未济测试通过"
