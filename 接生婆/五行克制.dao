# 五行克制测试
# 整数→金  字符串→火  列表→木  字典→土  浮点→水
# 克制：金克木 水克火 木克土 火克金 土克水

结界 "五行验证" {
    # 测试1：坎卦安全运算（金+金，无克制，正常）
    乾 "数值"  1000  金
    坎 "数值"  +  100
    兑 "数值"

    # 测试2：坎卦安全运算（火克金，静默失败，值不变）
    乾 "密码"  42  金
    坎 "密码"  +  "字符串"
    兑 "密码"

    坤
}

# 天道阻断：震卦走坤道（厚德载物，尝试执行），火克金 → apply_op 自然报错
# 蹇卦(39)·水山蹇·君子以反身修德 → 捕获预期错误，验证克制后果
结界 "阻断测试" {
    乾 "密码"  42  金
    蹇 {
        震 "密码"  +  "字符串"
    }
    化 "克制错" {
        兑 "克制错"
    }
    # 蹇化之后，密码应保持原值（震未成功执行）
    讼 "密码" == 42
    坤
}
