# listtest.dao — 测试小畜清空+巽迭代行为

小畜 "buf"
小畜 "buf" "A"
小畜 "buf" "B"
小畜 "buf" "C"
兑 "=== 初始buf（应为3项）==="
巽 "buf" "x" {
    兑 "x"
}

# 清空并重建（模拟消耗token）
小畜 "rest"
乾 "got" 0 土
巽 "buf" "item" {
    艮 "got" == 0 {
        兑 "=== 消耗: ==="
        兑 "item"
        乾 "got" 1 土
    } 否 {
        小畜 "rest" item
    }
}
小畜 "buf"
巽 "rest" "r" {
    小畜 "buf" r
}
兑 "=== 重建后buf（应为2项）==="
巽 "buf" "x" {
    兑 "x"
}
