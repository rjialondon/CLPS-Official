# 渐(53)·风山渐卦测试 — 序列生成器

# 步：整数范围
震 "r1" 【风山渐卦】 步 0 5
兑 "r1"
震 "r1_n" 【风雷益卦】 个数 r1
讼 "r1_n" == 5

# 步：起点不为0
震 "r2" 【风山渐卦】 步 3 8
兑 "r2"
震 "r2_n" 【风雷益卦】 个数 r2
讼 "r2_n" == 5

# 步：步长2（偶数）
震 "r3" 【风山渐卦】 步 0 10 2
兑 "r3"
震 "r3_n" 【风雷益卦】 个数 r3
讼 "r3_n" == 5

# 步：倒序
震 "r4" 【风山渐卦】 步 5 0 -1
兑 "r4"
震 "r4_n" 【风雷益卦】 个数 r4
讼 "r4_n" == 5

# 重复
震 "rep" 【风山渐卦】 重 "x" 4
兑 "rep"
震 "rep_n" 【风雷益卦】 个数 rep
讼 "rep_n" == 4

# 等差数列：从1开始，共5项，步长3 → [1,4,7,10,13]
震 "arith" 【风山渐卦】 等差 1 5 3
兑 "arith"
震 "arith_n" 【风雷益卦】 个数 arith
讼 "arith_n" == 5

# 等比数列：从1开始，共5项，比2 → [1,2,4,8,16]
震 "geo" 【风山渐卦】 等比 1 5 2
兑 "geo"
震 "geo_n" 【风雷益卦】 个数 geo
讼 "geo_n" == 5

# 斐波那契
震 "fib" 【风山渐卦】 斐 8
兑 "fib"
震 "fib_n" 【风雷益卦】 个数 fib
讼 "fib_n" == 8

# 素数：前10个
震 "primes" 【风山渐卦】 素数 10
兑 "primes"
震 "primes_n" 【风雷益卦】 个数 primes
讼 "primes_n" == 10

# 轮：循环取 list 共8次
震 "abc" 【地天泰卦】 劈 "a,b,c" ","
震 "cycled" 【风山渐卦】 轮 abc 8
兑 "cycled"
震 "cycled_n" 【风雷益卦】 个数 cycled
讼 "cycled_n" == 8

# 积
震 "small" 【风山渐卦】 步 1 6
震 "prod" 【风山渐卦】 积 small
兑 "prod"
讼 "prod" == 120

# 累和
震 "cumsum" 【风山渐卦】 累和 small
兑 "cumsum"
震 "cumsum_n" 【风雷益卦】 个数 cumsum
讼 "cumsum_n" == 5

